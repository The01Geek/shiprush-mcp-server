SHIPRUSH_ENV=sandbox

# Local development: set your token here
SHIPRUSH_SHIPPING_TOKEN_SANDBOX=your-sandbox-token-here
SHIPRUSH_SHIPPING_TOKEN_PRODUCTION=your-production-token-here

# AgentCore deployment: token is stored in AgentCore Identity vault instead.
# See docs/agentcore-deployment-guide.md for setup instructions.

# AWS AgentCore Deployment
AWS_REGION=us-east-1
AGENTCORE_NAME=shiprush_mcp_server

# Standalone mode (App Runner / ECS behind AgentCore Gateway)
# DOCKER_CONTAINER=1
# STANDALONE=1
# MCP_API_KEY=your-api-key-here  # optional: validates X-API-Key header
